{
  "name": "@job-aggregator/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node scripts/prisma-with-env.mjs generate && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/prisma-with-env.mjs generate",
    "db:migrate": "node scripts/prisma-with-env.mjs migrate deploy",
    "db:dev": "node scripts/prisma-with-env.mjs migrate dev",
    "db:studio": "node scripts/prisma-with-env.mjs studio"
  },
  "dependencies": {
    "@job-aggregator/shared": "*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
